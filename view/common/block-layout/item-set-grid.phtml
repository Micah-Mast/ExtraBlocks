<?php if (empty($items)): ?>
    <p><?php echo $this->translate('No items found.'); ?></p>
<?php else: ?>
    <?php
    $viewMode = $this->params()->fromQuery('view_mode_' . $blockId, 'grid');
    ?>
    <div class="item-set-grid-block" style="
        --grid-item-width:  <?php echo htmlspecialchars($itemWidth); ?>;
        --grid-item-height: <?php echo htmlspecialchars($itemHeight); ?>;
        --grid-item-border: <?php echo htmlspecialchars($borderColor); ?>;
        --grid-item-radius: <?php echo htmlspecialchars($borderRadius); ?>;
    ">
        <div style="display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; margin-bottom: 20px;">

            <div class="item-set-grid__view-toggle">
                <a href="?<?php echo http_build_query(['grid_page_' . $blockId => $page, 'sort_by' => $sortBy, 'sort_order' => $sortOrder, 'view_mode_' . $blockId => 'grid']); ?>"
                   class="item-set-grid__view-btn <?php echo $viewMode === 'grid' ? 'active' : ''; ?>"
                   title="<?php echo $this->translate('Grid view'); ?>">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                        <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
                    </svg>
                </a>
                <a href="?<?php echo http_build_query(['grid_page_' . $blockId => $page, 'sort_by' => $sortBy, 'sort_order' => $sortOrder, 'view_mode_' . $blockId => 'list']); ?>"
                   class="item-set-grid__view-btn <?php echo $viewMode === 'list' ? 'active' : ''; ?>"
                   title="<?php echo $this->translate('List view'); ?>">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <rect x="3" y="4" width="18" height="3"/><rect x="3" y="10" width="18" height="3"/>
                        <rect x="3" y="16" width="18" height="3"/>
                    </svg>
                </a>
            </div>

            <div>
                <?php echo $this->partial('common/block-layout/pagination', [
                    'page'       => $page,
                    'totalPages' => $totalPages,
                    'sortBy'     => $sortBy,
                    'sortOrder'  => $sortOrder,
                    'totalCount' => $totalCount,
                    'perPage'    => $perPage,
                    'viewMode'   => $viewMode,
                    'blockId'    => $blockId,
                ]); ?>
            </div>

            <div class="item-set-grid__controls" style="justify-self: end;">
                <select id="sort-dropdown" class="item-set-grid__sort-dropdown" style="width: auto;"
                    onchange="window.location.href = '?' + new URLSearchParams({
                        'sort_by_<?php echo $blockId; ?>': this.value,
                        'grid_page_<?php echo $blockId; ?>': 1,
                        'sort_order_<?php echo $blockId; ?>': document.getElementById('sort-order-dropdown-<?php echo $blockId; ?>').value,
                        'view_mode_<?php echo $blockId; ?>': '<?php echo htmlspecialchars($viewMode); ?>'
                    }).toString();" <?php
                    $sortOptions = [
                        'title'           => 'Title',
                        'dcterms:date'    => 'Date',
                        'dcterms:creator' => 'Author/Creator',
                    ];
                    foreach ($sortOptions as $value => $label):
                        $isActive = $sortBy === $value;
                    ?> >
                        <option value="<?php echo htmlspecialchars($value); ?>" <?php echo $isActive ? 'selected' : ''; ?>>
                            <?php echo htmlspecialchars($this->translate($label)); ?>
                        </option>
                    <?php endforeach; ?>
                </select>
                <select id="sort-order-dropdown-<?php echo $blockId; ?>" class="item-set-grid__sort-dropdown" style="width: auto;"
                    onchange="window.location.href = '?' + new URLSearchParams({
                        'sort_by_<?php echo $blockId; ?>': document.getElementById('sort-dropdown').value,
                        'grid_page_<?php echo $blockId; ?>': 1,
                        'sort_order_<?php echo $blockId; ?>': this.value,
                        'view_mode_<?php echo $blockId; ?>': '<?php echo htmlspecialchars($viewMode); ?>'
                    }).toString();" >
                    <option value="asc" <?php echo ($sortOrder === 'asc') ? 'selected' : ''; ?>><?php echo $this->translate('Ascending'); ?></option>
                    <option value="desc" <?php echo ($sortOrder === 'desc') ? 'selected' : ''; ?>><?php echo $this->translate('Descending'); ?></option>
                </select>
            </div>
        </div>

        <?php if ($viewMode === 'grid'): ?>
            <div class="item-set-grid__grid">
                <?php foreach ($items as $item): ?>
                    <?php
                    $title        = $item->displayTitle();
                    $itemUrl      = $item->siteUrl();
                    $primaryMedia = $item->primaryMedia();
                    $thumbnail    = $primaryMedia
                        ? $this->thumbnail($primaryMedia, 'large', ['alt' => $title])
                        : '<div class="item-set-grid__no-thumb"></div>';
                    $dateValue = $item->value('dcterms:date') ?? $item->value('dcterms:created');
                    $date      = $dateValue ? $dateValue->asHtml() : '';
                    ?>
                    <a class="item-set-grid__item" href="<?php echo htmlspecialchars($itemUrl); ?>">
                        <div class="item-set-grid__thumb">
                            <?php echo $thumbnail; ?>
                        </div>
                        <div class="item-set-grid__info">
                            <span class="item-set-grid__title"><?php echo htmlspecialchars($title); ?></span>
                            <?php if ($date): ?>
                                <span class="item-set-grid__date"><?php echo htmlspecialchars($date); ?></span>
                            <?php endif; ?>
                        </div>
                    </a>
                <?php endforeach; ?>
            </div>
                            
            <?php else: ?>
            <div class="item-set-grid__list">
                <?php foreach ($items as $item): ?>
                    <?php
                    $title        = $item->displayTitle();
                    $itemUrl      = $item->siteUrl();
                    $primaryMedia = $item->primaryMedia();
                    $thumbnail    = $primaryMedia
                        ? $this->thumbnail($primaryMedia, 'large', ['alt' => $title])
                        : '<div class="item-set-list__no-thumb"></div>';
                    $dateValue   = $item->value('dcterms:date') ?? $item->value('dcterms:created');
                    $date        = $dateValue ? $dateValue->asHtml() : '';
                    $authorValue = $item->value('dcterms:creator');
                    $author      = $authorValue ? $authorValue->asHtml() : '';
                    ?>
                    <a class="item-set-list__item" href="<?php echo htmlspecialchars($itemUrl); ?>">
                        <div class="item-set-list__thumb">
                            <?php echo $thumbnail; ?>
                        </div>
                        <div class="item-set-list__info">
                            <span class="item-set-list__title"><?php echo htmlspecialchars($title); ?></span>
                            <?php if ($author): ?>
                                <span class="item-set-list__author"><?php echo htmlspecialchars($author); ?></span>
                            <?php endif; ?>
                            <?php if ($date): ?>
                                <span class="item-set-list__date"><?php echo htmlspecialchars($date); ?></span>
                            <?php endif; ?>
                        </div>
                    </a>
                <?php endforeach; ?>
            </div>
        <?php endif; ?>

        <div style="margin-top: 30px;">
            <?php echo $this->partial('common/block-layout/pagination', [
                'page'       => $page,
                'totalPages' => $totalPages,
                'sortBy'     => $sortBy,
                'sortOrder'  => $sortOrder,
                'totalCount' => $totalCount,
                'perPage'    => $perPage,
                'viewMode'   => $viewMode,
                'blockId'    => $blockId,
            ]); ?>
        </div>
<?php endif; ?>
</div>